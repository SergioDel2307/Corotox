<?php
include("conexion.php");

/* Contador productos críticos */
$criticos = 0;

$sql_alerta = "SELECT * FROM articulos";
$resultado_alerta = $conn->query($sql_alerta);

while($fila_alerta = $resultado_alerta->fetch_assoc()){
    if($fila_alerta['cantidades_actuales'] <= $fila_alerta['stock_minimo']){
        $criticos++;
    }
}

/* Ordenar por stock más bajo */
$sql = "SELECT * FROM articulos ORDER BY cantidades_actuales ASC";
$resultado = $conn->query($sql);
?>

