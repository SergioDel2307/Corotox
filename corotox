CREATE DATABASE corotox;

USE corotox;

CREATE TABLE usuarios (

id INT AUTO_INCREMENT PRIMARY KEY,

nombres VARCHAR(100),
apellidos VARCHAR(100),
cedula VARCHAR(20),
direccion VARCHAR(150),
telefono VARCHAR(20),

usuario VARCHAR(50) UNIQUE,
correo VARCHAR(100),
password VARCHAR(255),

rol ENUM('admin','usuario') DEFAULT 'usuario',

codigo_recuperacion VARCHAR(10),
fecha_codigo TIMESTAMP,

fecha_creacion TIMESTAMP DEFAULT CURRENT_TIMESTAMP

);

INSERT INTO usuarios (usuario, password)
VALUES ('admin', SHA2('123456', 256));


CREATE TABLE articulos (
    id INT AUTO_INCREMENT PRIMARY KEY,
    categoria ENUM('Escoja una opcion','Maquina','Articulo','Servicio') DEFAULT 'Escoja una opcion',
    marca VARCHAR(100),
    referencia VARCHAR(100),
    nivel_rotacion ENUM('Escoja una opcion','Alta','Media','Baja') DEFAULT 'Escoja una opcion',
    codigo VARCHAR(50) UNIQUE,
    stock_minimo INT DEFAULT 1,
    stock_maximo INT DEFAULT 5,
    ubicacion VARCHAR(100) DEFAULT '-',
    fecha_registro TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

ALTER TABLE articulos 
ADD cantidades_actuales INT DEFAULT 0;
